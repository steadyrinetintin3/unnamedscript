                                    break
                                end
                            end
                            if not hasEvidence then
                                isPossible = false
                                break
                            end
                        end
                    end
                    if isPossible then
                        validGhosts[ghostName] = true
                    end
                end
            end

            for _, child in ipairs(ParentFrame:GetChildren()) do
                if child.Name == "PossibleGhost" then
                    local ghostName = child.TextLabel.Text
                    if not validGhosts[ghostName] then
                        child:Destroy()
                    end
                end
            end

            local Order = 500
            for ghostName in pairs(validGhosts) do
                local alreadyExists = false
                for _, child in ipairs(ParentFrame:GetChildren()) do
                    if child.Name == "PossibleGhost" and child.TextLabel.Text == ghostName then
                        alreadyExists = true
                        child.LayoutOrder = Order
                        break
                    end
                end

                if not alreadyExists then
                    CreateLog(ghostName, ParentFrame, Order, 165, true, "PossibleGhost", false)
                end
            end
        end

