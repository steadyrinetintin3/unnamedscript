local function CreateSlider(inner, Parent, Order, SizeX, TextScaled, min, max, type, callback)
    min = min or 0
    max = max or 100

    local Log = Instance.new("Frame")
    Log.LayoutOrder = Order or 0
    Log.Parent = Parent
    Log.AutomaticSize = Enum.AutomaticSize.Y
    Log.Size = UDim2.new(0, SizeX, 0, 28)
    Log.Name = type

    local UICornerLog = Instance.new("UICorner")
    UICornerLog.Parent = Log
    UICornerLog.CornerRadius = UDim.new(0, 10)

    local UIGradientLog = Instance.new("UIGradient")
    UIGradientLog.Parent = Log
    UIGradientLog.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(192, 75, 91)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(91, 33, 37))
    }

    local TextLabelLog = Instance.new("TextLabel", Log)
    TextLabelLog.TextWrapped = true
    TextLabelLog.BorderSizePixel = 0
    TextLabelLog.TextScaled = TextScaled
    TextLabelLog.TextSize = 12
    TextLabelLog.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    TextLabelLog.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
    TextLabelLog.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextLabelLog.BackgroundTransparency = 1
    TextLabelLog.Size = UDim2.new(0, SizeX, 0, 28)

    local SliderStroke = Instance.new("UIStroke", Log)
    SliderStroke.Color = Color3.fromRGB(255, 255, 255)
    SliderStroke.Thickness = 2

    local function update(value)
        local displayValue = math.floor(value)
        Settings[type] = displayValue
        
        local pct = (value - min) / (max - min)
        pct = math.clamp(pct, 0, 1)

        UIGradientLog.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(math.clamp(pct, 0, 0.999), 0),
            NumberSequenceKeypoint.new(math.clamp(pct + 0.001, 0.001, 1), 1),
            NumberSequenceKeypoint.new(1, 1)
        })

        TextLabelLog.Text = inner .. ": " .. displayValue
        
        if callback then callback(displayValue) end
    end

    update(Settings[type] or min)

    local holding = false
    Log.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = true
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if holding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            Guis["FrameDragDetector"].Enabled = false
            local relativeX = input.Position.X - Log.AbsolutePosition.X
            local pct = math.clamp(relativeX / Log.AbsoluteSize.X, 0, 1)
            local newValue = min + ((max - min) * pct)
            update(newValue)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Guis["FrameDragDetector"].Enabled = true
            holding = false
        end
    end)

    return {
        Gui = Log,
        Update = update
    }
end

