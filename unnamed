local function FadeOutWithSaves(container, duration)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    
    for _, v in pairs(container:GetDescendants()) do
        local currentProperties = {}
        local targetProperties = {}
        savedTabStates[v] = savedTabStates[v] or {}

        if v:IsA("Frame") or (v:IsA("ScrollingFrame")) or v:IsA("ViewportFrame") then
            currentProperties["BackgroundTransparency"] = v.BackgroundTransparency
            targetProperties["BackgroundTransparency"] = 1
        elseif v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
            currentProperties["BackgroundTransparency"] = v.BackgroundTransparency
            currentProperties["TextTransparency"] = v.TextTransparency
            targetProperties["BackgroundTransparency"] = 1
            targetProperties["TextTransparency"] = 1
        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then
            currentProperties["BackgroundTransparency"] = v.BackgroundTransparency
            currentProperties["ImageTransparency"] = v.ImageTransparency
            targetProperties["BackgroundTransparency"] = 1
            targetProperties["ImageTransparency"] = 1
        elseif v:IsA("Texture") then
            currentProperties["Transparency"] = v.Transparency
            targetProperties["Transparency"] = 1
        elseif v:IsA("BasePart") or v:IsA("UIStroke") then
            savedTabStates[v].Transparency = v.Transparency
        elseif v:IsA("UIGradient") and v.Parent.Name == "Divider" then
            savedTabStates[v] = { Transparency = v.Transparency }
            
            task.spawn(function()
                local startTime = os.clock()
                while os.clock() - startTime < duration do
                    local elapsed = os.clock() - startTime
                    local linearAlpha = math.clamp(elapsed / duration, 0, 1)
                    local sineAlpha = 0.5 - 0.5 * math.cos(linearAlpha * math.pi)
                    
                    local initialSequence = savedTabStates[v].Transparency
                    local targetPoints = {}
                    for _, keypoint in ipairs(initialSequence.Keypoints) do
                        local currentVal = keypoint.Value + (1 - keypoint.Value) * sineAlpha
                        table.insert(targetPoints, NumberSequenceKeypoint.new(keypoint.Time, currentVal))
                    end
                    v.Transparency = NumberSequence.new(targetPoints)
                    task.wait()
                end

                v.Color = ColorSequence.new{ColorSequenceKeypoint.new(0.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(0.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(0.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255)),ColorSequenceKeypoint.new(1.000, Color3.fromRGB(255, 255, 255))};
                
                v.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0.000, 0),
                    NumberSequenceKeypoint.new(0.167, 0.375),
                    NumberSequenceKeypoint.new(0.500, 0.106),
                    NumberSequenceKeypoint.new(0.650, 0.419),
                    NumberSequenceKeypoint.new(1.000, 0)
                })
            end)
        end

        if next(targetProperties) then
            savedTabStates[v] = currentProperties
            TweenService:Create(v, tweenInfo, targetProperties):Play()
        end
    end
end

local function FadeInWithSaves(container, duration)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    
    for _, v in pairs(container:GetDescendants()) do
        local savedProperties = savedTabStates[v]
        
        if savedProperties then
            if v:IsA("UIGradient") then
                local initialSequence = savedProperties.Transparency
                
                task.spawn(function()
                    local startTime = os.clock()
                    while os.clock() - startTime < duration do
                        local elapsed = os.clock() - startTime
                        local linearAlpha = math.clamp(elapsed / duration, 0, 1)
                        local sineAlpha = 0.5 - 0.5 * math.cos(linearAlpha * math.pi)
                        
                        local targetPoints = {}
                        for _, keypoint in ipairs(initialSequence.Keypoints) do
                            local currentVal = 1 - ((1 - keypoint.Value) * sineAlpha)
                            table.insert(targetPoints, NumberSequenceKeypoint.new(keypoint.Time, currentVal))
                        end
                        
                        v.Transparency = NumberSequence.new(targetPoints)
                        task.wait()
                    end
                    v.Transparency = initialSequence
                end)
            else
                TweenService:Create(v, tweenInfo, savedProperties):Play()
            end
        else
            local fallbackProperties = {}
            if (v:IsA("Frame") and not v.Name == "Text") or v:IsA("ViewportFrame") then
                fallbackProperties["BackgroundTransparency"] = 0
            elseif v:IsA("ScrollingFrame") then
                fallbackProperties["BackgroundTransparency"] = 1
            elseif v:IsA("TextLabel") or v:IsA("TextBox") or (v:IsA("TextButton") and not v.Name == "Button") then
                fallbackProperties["BackgroundTransparency"] = 1
                fallbackProperties["TextTransparency"] = 0
            elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then
                fallbackProperties["BackgroundTransparency"] = 1
                fallbackProperties["ImageTransparency"] = 0
            elseif v:IsA("Texture") then
                fallbackProperties["Transparency"] = 0
            elseif v:IsA("BasePart") or v:IsA("UIStroke") then
                if savedProperties and savedProperties.Transparency ~= nil then
                    TweenService:Create(v, tweenInfo, {
                        Transparency = savedProperties.Transparency
                    }):Play()
                end
            elseif v:IsA("UIGradient") and v.Parent.Name == "Divider" then
                local fallbackSequence = NumberSequence.new{NumberSequenceKeypoint.new(0.000, 0), NumberSequenceKeypoint.new(0.167, 0.375), NumberSequenceKeypoint.new(0.500, 0.106), NumberSequenceKeypoint.new(0.650, 0.419), NumberSequenceKeypoint.new(1.000, 0)}
                
                task.spawn(function()
                    local startTime = os.clock()
                    while os.clock() - startTime < duration do
                        local elapsed = os.clock() - startTime
                        local linearAlpha = math.clamp(elapsed / duration, 0, 1)
                        local sineAlpha = 0.5 - 0.5 * math.cos(linearAlpha * math.pi)
                        
                        local targetPoints = {}
                        for _, keypoint in ipairs(fallbackSequence.Keypoints) do
                            local currentVal = 1 - ((1 - keypoint.Value) * sineAlpha)
                            table.insert(targetPoints, NumberSequenceKeypoint.new(keypoint.Time, currentVal))
                        end
                        
                        v.Transparency = NumberSequence.new(targetPoints)
                        task.wait()
                    end
                    v.Transparency = NumberSequence.new({
                        NumberSequenceKeypoint.new(0.000, 0),
                        NumberSequenceKeypoint.new(0.167, 0.375),
                        NumberSequenceKeypoint.new(0.500, 0.106),
                        NumberSequenceKeypoint.new(0.650, 0.419),
                        NumberSequenceKeypoint.new(1.000, 0)
                    })
                end)
            end

            if next(fallbackProperties) then
                TweenService:Create(v, tweenInfo, fallbackProperties):Play()
            end
        end
    end
end

local function FadeIn(time, v)
    local tweenInfo = TweenInfo.new(time, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, 0, false, 0)
    local targets = {}

    if v:IsA("Frame") or (v:IsA("ScrollingFrame") and v.Name ~= "UserConsoleInfo") or v:IsA("TextBox") then
        targets["BackgroundTransparency"] = 1
    end

    if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
        targets["BackgroundTransparency"] = 1
        targets["TextTransparency"] = 1
    end

    if v:IsA("ImageLabel") or v:IsA("ImageButton") then
        targets["ImageTransparency"] = 1
    end

    if v:IsA("UIStroke") or v:IsA("BasePart") or v:IsA("Decal") or v:IsA("Texture") then
        targets["Transparency"] = 1
    end

    if next(targets) then
        TweenService:Create(v, tweenInfo, targets):Play()
    else
        if v:IsA("UIGradient") then
            TweenService:Create(v, tweenInfo, {Offset = Vector2.new(1, 0)}):Play()
        end
    end
end

local function FadeOut(time, v, transparency)
    local tweenInfo = TweenInfo.new(time, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, 0, false, 0)
    if not transparency then
        transparency = 0
    end
    local targets = {}

    if v:IsA("Frame") or (v:IsA("ScrollingFrame") and v.Name ~= "UserConsoleInfo") or v:IsA("TextBox") then
        targets["BackgroundTransparency"] = transparency
    end

    if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
        targets["BackgroundTransparency"] = transparency
        targets["TextTransparency"] = transparency
    end

    if v:IsA("ImageLabel") or v:IsA("ImageButton") then
        targets["ImageTransparency"] = transparency
    end

    if v:IsA("UIStroke") or v:IsA("BasePart") or v:IsA("Decal") or v:IsA("Texture") then
        targets["Transparency"] = transparency
    end

    if next(targets) then
        TweenService:Create(v, tweenInfo, targets):Play()
    else
        if v:IsA("UIGradient") then
            TweenService:Create(v, tweenInfo, {Offset = Vector2.new(1, 0)}):Play()
        end
    end
end

