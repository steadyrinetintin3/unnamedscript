    local function CreateEvidence(who, destroy, text, text2, rewrite, distance)
        if not evidence then evidence = true end
        if not text2 then text2 = "Evidence" end
        if not rewrite then rewrite = false end
        if not distance then distance = 2.5 end
        
        if not destroy then
            if who:FindFirstChild("Esp2") and not rewrite then return end
            if not rewrite then
                local Bill = Instance.new("BillboardGui")
                Bill.Parent = who
                Bill.AlwaysOnTop = true
                Bill.Name = "Esp2"
                Bill.Size = UDim2.new(4, 0, 1, 0)
                Bill.SizeOffset = Vector2.new(0, distance)
                local Frame = Instance.new("Frame", Bill)
                Frame.Size = UDim2.new(1, 0, 1, 0)
                Frame.BackgroundTransparency = 1
                CreateItems(Frame, "DarkRed2")
                local Text = Instance.new("TextLabel", Bill)
                Text.TextColor3 = Color3.fromRGB(255, 255, 255)
                Text.Size = UDim2.new(1, 0, 0.7, 0)
                Text.BackgroundTransparency = 1
                Text.TextTransparency = 1
                Text.TextScaled = true
                Text.Text = text
                FadeOut(0.25, Frame, 0)
                FadeOut(0.25, Text, 0)
                task.wait(0.25)
                local info = TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                local twen = TweenService:Create(Frame, info, {Size = UDim2.new(1, 0, 2, 0)})
                twen:Play()
                twen.Completed:Connect(function()
                    local Text2 = Instance.new("TextLabel", Bill)
                    Text2.Name = "Evidence"
                    Text2.TextColor3 = Color3.fromRGB(255, 255, 255)
                    Text2.Size = UDim2.new(1, 0, 0.7, 0)
                    Text2.BackgroundTransparency = 1
                    Text2.MaxVisibleGraphemes = 0
                    Text2.Position = UDim2.new(0, 0, 0.99, 0)
                    Text2.TextScaled = true
                    Text2.Text = text2
                    for i = 1, 30 do
                        Text2.MaxVisibleGraphemes = i
                        task.wait(0.025)
                    end
                    FadeOut(0.25, Text2, 0)
                end)
            else
                local Bill = who:FindFirstChild("Esp2")
                local Text2 = Bill and Bill:FindFirstChild("Evidence")
                local Text = Bill and Bill:FindFirstChildOfClass("TextLabel")
                if Text and Text2 then
                    for i = string.len(Text2.Text), 0, -1 do
                        Text2.MaxVisibleGraphemes = i
                        task.wait(0.025)
                    end
                    Text.Text = text
                    Text2.Text = text2
                    for i = 1, #text2 do
                        Text2.MaxVisibleGraphemes = i
                        task.wait(0.025)
                    end
                end
            end
        else
            local Bill = who:FindFirstChild("Esp2")
            if Bill then
                for _, v in pairs(Bill:GetDescendants()) do
                    if v:IsA("Frame") or v:IsA("TextLabel") then
                        FadeOut(0.25, v, 1)
                    end
                end
                task.wait(0.25)
                Bill:Destroy()
            end
        end
    end

