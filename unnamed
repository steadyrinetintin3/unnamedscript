                    connection:Disconnect()
                    
                    task.defer(function()
                        isselecting = false
                    end)
                end)
            end)
            PlayerCont.Activated:Connect(function()
                if isselecting then return end
                
                local ctext = PlayerCont:FindFirstChild("TextLabel")
                if not ctext then return end

                isselecting = true
                local oldText = ctext.Text
                ctext.Text = "..."
                
                UIS.ModalEnabled = true
                
                local connection
                connection = UIS.InputBegan:Connect(function(input, gameProcessed)
                    if input.KeyCode == Enum.KeyCode.Escape then
                        ctext.Text = oldText
                        isselecting = false
                        UIS.ModalEnabled = false
                        connection:Disconnect()
                        return
                    end

                    if gameProcessed then return end
                    
                    SetKeybind("Player", input.KeyCode.Name)
                    ctext.Text = "Player aimbot keybind: " .. input.KeyCode.Name
                    
                    UIS.ModalEnabled = false
                    connection:Disconnect()
                    
                    task.defer(function()
                        isselecting = false
                    end)
                end)
            end)
            CloseCont.Activated:Connect(function()
                if isselecting then return end
                
                local ctext = CloseCont:FindFirstChild("TextLabel")
                if not ctext then return end

                isselecting = true
                local oldText = ctext.Text
                ctext.Text = "..."
                
                UIS.ModalEnabled = true
                
                local connection
                connection = UIS.InputBegan:Connect(function(input, gameProcessed)
                    if input.KeyCode == Enum.KeyCode.Escape then
                        ctext.Text = oldText
                        isselecting = false
                        UIS.ModalEnabled = false
                        connection:Disconnect()
                        return
                    end

                    if gameProcessed then return end
                    
                    SetKeybind("Toggle", input.KeyCode.Name)
                    ctext.Text = "Toggle Keybind: " .. input.KeyCode.Name
                    
                    UIS.ModalEnabled = false
                    connection:Disconnect()
                    
                    task.defer(function()
                        isselecting = false
                    end)
                end)
            end)
            UIS.InputBegan:Connect(function(input, gameProcessed)
                if gameProcessed then return end
                if isselecting then return end
                
                if input.KeyCode.Name == togglekeybind then
                    togglevis()
                end
            end)
        else
            CloseCont.Activated:Connect(function()
                togglevis()
            end)
            GhostCont.Activated:Connect(function()
                isAiming = not isAiming
                game:GetService("RunService").RenderStepped:Connect(function()
                    if isAiming then
                        Workspace.Camera.CFrame = CFrame.lookAt(Workspace.Camera.CFrame.Position, Ghost.HumanoidRootPart.Position)
                    end
                end)
            end)
            local ct = nil
            PlayerCont.Activated:Connect(function()
                isAiming = not isAiming
                local found = false
                local targets = {}
                for _, v in pairs(workspace:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v ~= Character then
                        table.insert(targets, v)
                    end
                end
                
                for i, v in ipairs(targets) do
                    if v == ct then
                        ct = targets[i + 1] or targets[1]
                        found = true
                        break
                    end
                end
                if not found then ct = targets[1] end
            end)
            game:GetService("RunService").RenderStepped:Connect(function()
                if isAiming and ct and ct:FindFirstChild("HumanoidRootPart") then
                    workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, ct.HumanoidRootPart.Position)
                end
            end)
        end

        local function LoadPresetF(name)
            local data = Presets[name]
            if data then
                AE = data.AE
                AP = data.AP
                AG = data.AG
                AB = data.AB
                Max = data.Max
                AF = data.AF
                AES = data.AES
                NOH = data.NOH
                IEsp = data.IEsp
                Notify = data.Notify
                GEs = data.GEs
                ev = data.ev
                PlEs = data.PlEs
                RM = data.RM
                Fb = data.Fb
                isInf = data.isInf
                val = data.val
                val2 = data.val2
            end

            if Humanoid then
                if data.WalkSpeed then Humanoid.WalkSpeed = data.WalkSpeed end
                if data.JumpPower then Humanoid.JumpPower = data.JumpPower end
            end

            for key, value in pairs(data) do
                Settings[key] = value
                
                if Sliders[key] then
                    Sliders[key].Update(value)
                end
                
                if ToggleButtons[key] then
                    ToggleButtons[key].Update(value)
                end
            end

            task.spawn(function()
                if AE then
                    task.spawn(function()
                        while AE do
                            AutoMarkEvidences()
                            task.wait(0.1)
                        end
                    end)
                end
            end)
            task.spawn(function()
                if AG then
                    task.spawn(function()
                        while AG do
                            AutoMarkGhost()
                            task.wait(0.1)
                        end
                    end)
                end
            end)
            task.spawn(function()
                if AB then
                    task.spawn(function()
                        while AB do
                            AutoSb()
                            task.wait(0.1)
                        end
                    end)
                end
            end)
            task.spawn(function()
                if AES then
                    task.spawn(function()
                        while AES do
                            if RoomsFolder then
                                Ghost:GetAttributeChangedSignal("Hunting"):Connect(function()
                                    if AES and Ghost:GetAttribute("Hunting") == true then
                                        TPCamp()
                                    end
                                end)
                            end
                            task.wait(0.1)
                        end
                    end)
                end
            end)
            if NOH then
                task.spawn(function()
                    conn = Ghost:GetAttributeChangedSignal("Hunting"):Connect(function()
                        local currentHuntingState = Ghost:GetAttribute("Hunting")
                        
                        if currentHuntingState == true then
                            CreateNotification("Ghost hunt has started.", 2)
                        else
                            CreateNotification("Ghost hunt has ended.", 2)
                        end
                    end)
                end)
            else
                if conn then
                    conn:Disconnect()
                    conn = nil
                end
            end
            if IEsp then
                CItemEsp("Create")
            else
                CItemEsp("Destroy")
            end
            if Notify then
                task.spawn(function()
                    while Notify do
                        NotifyEv()
                        task.wait(0.1)
                    end
                end)
            end
            if GEs then
                CGhostEsp("Create")
            else
                CGhostEsp("Destroy")
            end
            if ev then
                CreateEvidenceEsp("Create")
            else
                CreateEvidenceEsp("Destroy")
            end
            task.spawn(function()
                if RM then
                    CreateRoomEsp("Create")
                else
                    CreateRoomEsp("Destroy")
                end
            end)
            task.spawn(function()
                if isInf then
                    task.spawn(function()
                        while isInf do
                            if Player:GetAttribute("Sprinting") == true then
                                Player:SetAttribute("Sprinting", false)
                            end
                            task.wait(0.1)
                        end
                    end)
                end
            end)
            task.spawn(function()
                if PlEs then
                    CPlayerEsp("Create")
                else
                    CPlayerEsp("Destroy")
                end
            end)
            task.spawn(function()
                if Fb then
                    if not game:GetService("Lighting"):FindFirstChild("Atmosphere") then
                        Instance.new("Atmosphere", game.Lighting)
                    end
                    ChangeLight("Light")
                    task.wait(1)
                else
                    if game:GetService("Lighting"):FindFirstChild("Atmosphere") then
                        game.Lighting.Atmosphere:Destroy()
                    end
                    ChangeLight("ha")
                    task.wait(1)
                end
            end)
        end
        

        CreatePreset.Activated:Connect(function()
            local count = 0
            for _ in pairs(Presets) do
                count = count + 1
            end
            if count >= 5 then
                CreateNotification("You've already reached the maximum of 5 presets", 2)
                return
            end

            local box, btn2 = CreateInner(Guis["2"], false)
            btn2.Activated:Connect(function()
                if box.Text == "" then 
                    CreateNotification("Please, give a name to the preset.", 2)
                    return 
                end
                if Presets[box.Text] then 
                    CreateNotification("There is already a preset wtih that name.", 2)
                    return 
                end

                Presets[box.Text] = GetPresetsTable()
                
                local pres = CreateButton(box.Text, Script, 7, 165, true)
                pres.Activated:Connect(function()
                    selectedpreset = pres
                    selectedpresetname = box.Text
                end)
                
                SavePresets("Presets")
                
                CreateInner(Guis["2"], true)
            end)
        end)

        DeletePreset.Activated:Connect(function()
            if selectedpreset and typeof(selectedpreset) == "Instance" then
                local presetName = selectedpreset.TextLabel.Text
                
                selectedpreset:Destroy()
                
                Presets[presetName] = nil
                
                SavePresets("Presets")
                
                selectedpreset = nil
            end
        end)

        local function LoadPresetsFromFile()
            if isfile(fpath) then
                local decoded = HttpService:JSONDecode(readfile(fpath))
                Presets = decoded
                
                for name, data in pairs(Presets) do
                    local pres = CreateButton(name, Script, 7, 165, true)
                    pres.Activated:Connect(function()
                        selectedpreset = pres
                        selectedpresetname = name
                    end)
                end
            end
        end

        LoadPresetsFromFile()

        LoadPreset.Activated:Connect(function()
            if selectedpresetname ~= "None" then
                LoadPresetF(selectedpresetname)
            else
                CreateNotification("Select a preset first.", 2)
            end
        end)

