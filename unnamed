    local function SavePresets(type)
        if not isfolder(folder) then
            makefolder(folder)
        end

        local success, encoded
        local table = {}

        if type == "Presets" then
            success, encoded = pcall(function()
                return HttpService:JSONEncode(Presets)
            end)
            if success then
                writefile(fpath, encoded)
            end
        end
        if type == "Toggle" then
            table = {
                togglekeybind = togglekeybind,
                ghostkeybind = ghostkeybind,
                playerkeybind = playerkeybind
            }

            success, encoded = pcall(function()
                return HttpService:JSONEncode(table)
            end)
            if success and table then writefile(fpath2, encoded) end
        end

        if success then
        else
            warn("Failed to encode: " .. tostring(encoded))
        end
    end

