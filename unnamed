                local IFClone = ItemsFolder:Clone()
                IFClone.Parent = Guis["MapView"]
            end
        end)

        local isDragging = false
        local lastMousePos = Vector2.new(0, 0)

        UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseWheel then return end

            local mousePos = UserInputService:GetMouseLocation()
            local guiObjects = Player.PlayerGui:GetGuiObjectsAtPosition(mousePos.X, mousePos.Y)
            for _, obj in ipairs(guiObjects) do
                if obj == Guis["MapView"] then
                    local change = (input.Position.Z > 0) and -5 or 5
                    Guis["Camera"].CFrame = Guis["Camera"].CFrame - Guis["Camera"].CFrame.LookVector * change
                    break
                end
            end
        end)

        Guis["MapView"].InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isDragging = true
                Guis["FrameDragDetector"].Enabled = false
                lastMousePos = UserInputService:GetMouseLocation()
            end
        end)

        Guis["MapView"].InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isDragging = false
                Guis["FrameDragDetector"].Enabled = true
            end
        end)

        Guis["MapView"].InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton2 then
                local framePos = Guis["MapView"].AbsolutePosition
                local frameSize = Guis["MapView"].AbsoluteSize
                local mousePos = UserInputService:GetMouseLocation()

                local MouseY = mousePos.Y - 36

                local relativeX = mousePos.X - framePos.X
                local relativeY = MouseY - framePos.Y

                if relativeX >= 0 and relativeX <= frameSize.X and relativeY >= 0 and relativeY <= frameSize.Y then
                    local mapCamera = Guis["MapView"].CurrentCamera
                    if mapCamera then
                        local viewportSize = mapCamera.ViewportSize
                        local scaledX = (relativeX / frameSize.X) * viewportSize.X
                        local scaledY = (relativeY / frameSize.Y) * viewportSize.Y

                        local ray = mapCamera:ViewportPointToRay(scaledX, scaledY)
                        local raycastResult = workspace:Raycast(ray.Origin, ray.Direction * 10000)

                        if raycastResult then
                            HumanoidRootPart.CFrame = CFrame.new(raycastResult.Position) * HumanoidRootPart.CFrame.Rotation
                        end
                    end
                end
            end
        end)
        game:GetService("RunService").RenderStepped:Connect(function()
            if not isDragging then return end
            local currentMousePos = UserInputService:GetMouseLocation()
            local delta = currentMousePos - lastMousePos
            if delta.Magnitude > 0 then
                local sensitivity = 0.1
                local currentPos = Guis["Camera"].CFrame.Position
                local newPos = currentPos + Vector3.new(delta.Y * sensitivity, 0, -delta.X * sensitivity)
                Guis["Camera"].CFrame = CFrame.new(newPos) * (Guis["Camera"].CFrame - currentPos)
                lastMousePos = currentMousePos
            end
        end)
    end)
