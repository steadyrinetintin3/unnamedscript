        local RunService = game:GetService("RunService")
        local UserInputService = game:GetService("UserInputService")

        local isDragging = false
        local lastMousePos = Vector2.new(0, 0)
        
        local dragDetector = Guis["2"]:FindFirstChildOfClass("UIDragDetector") 

        ItemsFolder.ChildAdded:Connect(function()
            if ItemsFolder then
                if Guis["MapView"]:FindFirstChild("Items") then Guis["MapView"].Items:Destroy() end
                local IFClone = ItemsFolder:Clone()
                IFClone.Parent = Guis["MapView"]
            end
        end)
