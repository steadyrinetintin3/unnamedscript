    local SliderStroke = Instance.new("UIStroke", Log)
    SliderStroke.Color = Color3.fromRGB(255, 255, 255)
    SliderStroke.Thickness = 2

    local function update(value)
        local pct = (value - min) / (max - min)
        pct = math.clamp(pct, 0, 0.999)

        UIGradientLog.Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(pct, 0),
            NumberSequenceKeypoint.new(pct + 0.001, 1),
            NumberSequenceKeypoint.new(1, 1)
        }

        TextLabelLog.Text = inner
    end

    update(min)

    local holding = false

    Log.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = true
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if holding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            Guis["FrameDragDetector"].Enabled = false
            local relativeX = input.Position.X - Log.AbsolutePosition.X
            local pct = math.clamp(relativeX / Log.AbsoluteSize.X, 0, 1)
            
            local newValue = min + ((max - min) * pct)
            update(newValue)
            
            task.spawn(function()
                while Humanoid do
                    if newValue == 0 then break end
                    if type == "WalkSpeed" then
                        Humanoid.WalkSpeed = newValue
                    elseif type == "JumpPower" then
                        Humanoid.JumpPower = newValue
                    elseif type == "Stamina" then
                        Player:SetAttribute("Stamina", newValue)
                    end
                    task.wait(0.1)
                end
            end)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Guis["FrameDragDetector"].Enabled = true
            holding = false
        end
    end)

    return TextLabelLog
end

