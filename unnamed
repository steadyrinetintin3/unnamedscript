    local function UpdateGhostLogs(ParentFrame, EvidencesTable)
        local validGhosts = {}

        if forcedGhost then
            validGhosts[forcedGhost] = true
        else
            for ghostName, requiredEvidences in pairs(GhostEvidences) do
                local isPossible = true
                for evidenceName, isActive in pairs(EvidencesTable) do
                    if isActive then
                        local hasEvidence = false
                        for _, req in ipairs(requiredEvidences) do
                            if req == evidenceName then
                                hasEvidence = true
                                break
                            end
                        end
                        if not hasEvidence then
                            isPossible = false
                            break
                        end
                    end
                end
                if isPossible then
                    validGhosts[ghostName] = true
                end
            end
        end

        for _, child in ipairs(ParentFrame:GetChildren()) do
            if child.Name == "PossibleGhost" then
                local ghostName = child.TextLabel.Text
                if not validGhosts[ghostName] then
                    child:Destroy()
                end
            end
        end

        local Order = 500
        for ghostName in pairs(validGhosts) do
            local alreadyExists = false
            for _, child in ipairs(ParentFrame:GetChildren()) do
                if child.Name == "PossibleGhost" and child.TextLabel.Text == ghostName then
                    alreadyExists = true
                    child.LayoutOrder = Order
                    break
                end
            end

            if not alreadyExists then
                CreateLog(ghostName, ParentFrame, Order, 165, true, "PossibleGhost", false)
            end
        end
    end

