    local function GetBB(should, name)
        if not Ghost then return nil end
        if not name then name = "GhostPart" end
        
        for _, v in pairs(RoomsFolder:GetChildren()) do
            if v.Name == GetGhostRoom() then
                local bbox = v:FindFirstChild("BoundingBox")
                if bbox then
                    local targetPos
                    if bbox:IsA("BasePart") then
                        targetPos = bbox.Position
                    elseif bbox:IsA("Folder") then
                        local total = Vector3.new(0, 0, 0)
                        local parts = bbox:GetChildren()
                        for _, part in pairs(parts) do
                            total = total + part.Position
                        end
                        targetPos = (#parts > 0) and (total / #parts) or Vector3.new(0,0,0)
                    end

                    if should then
                        local pt = Workspace:FindFirstChild(name) or Instance.new("Part", Workspace)
                        pt.Name = name
                        pt.Anchored = true
                        pt.Transparency = 1
                        pt.CanCollide = false
                        pt.Position = targetPos
                        return pt
                    else
                        return targetPos
                    end
                end
            end
        end
    end

